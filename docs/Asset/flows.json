    {
        "id": "parse_metrics",
        "type": "function",
        "z": "flow_main",
        "name": "Parse Sparkplug B Metrics",
        "func": "// Parse Sparkplug B metrics array into a flat object\nlet metrics = msg.payload.metrics || [];\nlet parsed = {};\n\nfor (let m of metrics) {\n    parsed[m.name] = m.value;\n}\n\nparsed.timestamp = msg.payload.timestamp;\nparsed.seq = msg.payload.seq;\n\nmsg.payload = parsed;\nmsg.topic = 'transformer01';\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 420,
        "y": 120,
        "wires": [
            [
                "dashboard_current",
                "dashboard_temp",
                "dashboard_anomaly",
                "dashboard_actuator",
                "influx_formatted"
            ]
        ]
    },
    {
        "id": "rul_function",
        "type": "function",
        "z": "flow_main",
        "name": "RUL Estimator (Linear Regression)",
        "func": "// =============================================================\n// Cloud RUL Estimation – Linear Regression\n// =============================================================\n// Extracts temperature from Sparkplug B metrics, maintains a\n// history buffer, and estimates Remaining Useful Life (hours)\n// until temperature reaches the 85°C threshold.\n\nlet temp = null;\nfor (let m of msg.payload.metrics) {\n    if (m.name === 'Temperature') temp = m.value;\n}\n\nif (temp === null) return msg;\n\n// Maintain history (last 60 values, ~2 min at 2s interval)\nlet history = flow.get('tempHistory') || [];\nhistory.push(temp);\nif (history.length > 60) history.shift();\nflow.set('tempHistory', history);\n\nlet rul = 'Learning...';\nlet rulHours = -1;\n\nif (history.length >= 10) {\n    let n = history.length;\n    let sumX = 0, sumY = 0, sumXY = 0, sumX2 = 0;\n    for (let i = 0; i < n; i++) {\n        sumX += i;\n        sumY += history[i];\n        sumXY += i * history[i];\n        sumX2 += i * i;\n    }\n    let slope = (n * sumXY - sumX * sumY) / (n * sumX2 - sumX * sumX);\n    let currentTemp = history[n - 1];\n    let threshold = 85.0;\n\n    if (slope > 0.01 && currentTemp < threshold) {\n        // Convert slope (per sample) to slope per hour\n        // Each sample is 2 seconds apart\n        let slopePerHour = slope * (3600 / 2);\n        let hours = (threshold - currentTemp) / slopePerHour;\n        rul = hours.toFixed(1) + ' hours';\n        rulHours = parseFloat(hours.toFixed(1));\n    } else if (currentTemp >= threshold) {\n        rul = 'CRITICAL';\n        rulHours = 0;\n    } else {\n        rul = 'Stable';\n        rulHours = 9999;\n    }\n}\n\n// Output RUL as a new message\nmsg.payload = {\n    rul: rul,\n    rulHours: rulHours,\n    currentTemp: temp,\n    historyLength: history.length,\n    timestamp: new Date().toISOString()\n};\n\nreturn msg;",
        "outputs": 1,
        "x": 440,
        "y": 420,
        "wires": [
            [
                "dashboard_rul",
                "influx_rul",
                "debug_rul"
            ]
        ]
    },
