    {
        "id": "influx_formatted",
        "type": "function",
        "z": "flow_main",
        "name": "Format for InfluxDB",
        "func": "// For 'influxdb out' node in single-measurement mode,\n// pass fields flat at the top level with no nesting\nmsg.measurement = 'transformer_data';\n\nmsg.payload = {\n    current:        parseFloat(msg.payload.Current)        || 0.0,\n    temperature:    parseFloat(msg.payload.Temperature)    || 0.0,\n    anomaly_score:  parseFloat(msg.payload.AnomalyScore)   || 0.0,\n    actuator_state: parseInt(msg.payload.ActuatorState)    || 0,\n    uptime:         parseInt(msg.payload.UptimeSeconds)    || 0\n};\n\nmsg.tags = {\n    device: 'transformer01',\n    plant:  'plant01',\n    group:  'group24'\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 700,
        "y": 140,
        "wires": [
            [
                "influx_write"
            ]
        ]
    },
    {
        "id": "influx_rul",
        "type": "function",
        "z": "flow_main",
        "name": "Format RUL for InfluxDB",
        "func": "// Format RUL data for InfluxDB - SIMPLE VERSION\nlet rul_hours = 0;\nlet rul_status = \"unknown\";\n\n// Extract RUL value from payload\nif (msg.payload.rul) {\n    if (typeof msg.payload.rul === 'object') {\n        rul_hours = parseFloat(msg.payload.rul.rul_hours) || 0;\n        rul_status = String(msg.payload.rul.rul_status || \"unknown\");\n    } else if (typeof msg.payload.rul === 'string') {\n        // Try to extract number from string like \"12.5 hours\"\n        let match = msg.payload.rul.match(/(\\d+(?:\\.\\d+)?)/);\n        rul_hours = match ? parseFloat(match[1]) : 0;\n        rul_status = msg.payload.rul;\n    } else {\n        rul_hours = parseFloat(msg.payload.rul) || 0;\n    }\n}\n\n// Format for InfluxDB - MUST be flat structure\nmsg.measurement = 'rul_estimation';\nmsg.fields = {\n    rul_hours: rul_hours,\n    rul_status: rul_status\n};\nmsg.tags = {\n    device: 'transformer01',\n    group: 'group24'\n};\nmsg.timestamp = Date.now() * 1000000;\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 720,
        "y": 420,
        "wires": [
            [
                "influx_write_rul"
            ]
        ]
    },
